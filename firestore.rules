rules_version = '2';

// SAMPADA.ai Firestore security rules
// Deploy:  firebase deploy --only firestore:rules
// (or paste into Firebase Console → Firestore Database → Rules)
service cloud.firestore {
  match /databases/{database}/documents {

    // A user may only read/write documents under their own UID.
    // Covers users/{uid}/watchlist/* and users/{uid}/sessions/*.
    // The backend Admin SDK bypasses these rules, so server-side
    // session writes and the _diagnostics health-check are unaffected.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
